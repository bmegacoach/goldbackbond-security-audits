# STRIPE CONFIGURATION - REQUIRED FOR PAYMENT FUNCTIONALITY
# Get these from your Stripe Dashboard → Developers → API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxx  # Or pk_test_xxxxxxx
VITE_STRIPE_SECRET_KEY=sk_live_xxxxxxxxx       # For backend (Supabase Edge Function)

# STRIPE PRICE IDs - REQUIRED FOR PAYMENT PROCESSING
# Get these from your Stripe Dashboard → Products → Pricing
VITE_STRIPE_SILVER_PRICE_ID=price_xxxxxxxxx     # For $3,500 Silver audit
VITE_STRIPE_GOLD_PRICE_ID=price_xxxxxxxxx       # For $6,500 Gold audit
VITE_STRIPE_PLATINUM_PRICE_ID=price_xxxxxxxxx   # For $9,500 Platinum audit

# SUPABASE CONFIGURATION - REQUIRED FOR BACKEND
# Get these from your Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# LIVE DATA API - OPTIONAL FOR DYNAMIC STATISTICS
# For real-time homepage statistics
X-API-KEY=your_live_api_key_here

# TELEGRAM INTEGRATION - OPTIONAL
# For enhanced Telegram features
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890
TELEGRAM_CHAT_ID=-1001234567890
